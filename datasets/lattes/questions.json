{
  "datasetId": "lattes-v2",
  "domain": "lattes",
  "language": "en",
  "questions": [
    {
      "id": "q_phd",
      "question": "Where and how long ago did the researcher complete their PhD?",
      "tags": ["objective", "factual", "simple"],
      "validation": {
        "type": "heuristic",
        "schema": {
          "type": "object",
          "properties": {
            "where": { "type": "string" },
            "yearsAgo": { "type": "number" }
          },
          "required": ["where", "yearsAgo"],
          "additionalProperties": false
        }
      }
    },
    {
      "id": "q_field",
      "question": "What is the main field of knowledge in which this researcher works?",
      "tags": ["objective", "factual", "simple"],
      "validation": {
        "type": "heuristic",
        "schema": { "type": "string" }
      }
    },
    {
      "id": "q_venue",
      "question": "Where does this researcher publish most frequently?",
      "tags": ["objective", "factual", "simple"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_coauth",
      "question": "Who are the most frequent co-authors of this researcher?",
      "tags": ["subjective", "factual", "simple"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_with_advisees",
      "question": "Does this researcher usually publish with their advisees?",
      "tags": ["subjective", "factual", "simple"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_adv_areas",
      "question": "What are the research areas of this researcher's advisees?",
      "tags": ["subjective", "simple"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_pub_2024",
      "question": "What is the most relevant bibliographic production of this researcher in 2024?",
      "tags": ["subjective", "simple"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_english",
      "question": "Does this researcher speak English?",
      "tags": ["objective", "factual", "simple"],
      "validation": {
        "type": "heuristic",
        "schema": {
          "type": "string",
          "enum": ["yes", "no"]
        }
      }
    },
    {
      "id": "q_not_aligned",
      "question": "How does the candidate’s academic and professional background align with the project '{project_not_aligned}'?",
      "tags": ["subjective", "factual", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_aligned",
      "question": "How does the candidate’s academic and professional background align with the project '{project_aligned}' ?",
      "tags": ["subjective", "factual", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_qualis_count",
      "question": "How many articles has the researcher published in indexed journals, and how many of them are in journals classified as A1 or A2 in the Qualis ranking of the field?",
      "tags": ["subjective", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_indexed_concentration",
      "question": "Are the researcher’s publications concentrated in indexed journals or conferences (e.g., Scopus, Web of Science, Qualis A1/A2)?",
      "tags": ["objective", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_citations",
      "question": "How many citations have the researcher’s articles received, and what is the average number of citations per article?",
      "tags": ["objective", "out-of-context", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_hindex",
      "question": "What is the researcher’s h-index, and how does it compare to the average in their field?",
      "tags": ["subjective", "out-of-context", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_projects_funding",
      "question": "How many funded research projects has the researcher coordinated or participated in, and which funding agencies supported them?",
      "tags": ["objective", "context-dependent", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_funding_amount",
      "question": "What is the total amount of research funding obtained by the researcher in the last five years?",
      "tags": ["objective", "out-of-context", "complex"],
      "validation": {
        "type": "judge"
      }
    },
    {
      "id": "q_supervision",
      "question": "How many students has the researcher supervised, and how many have completed their programs?",
      "tags": ["objective", "factual", "complex"],
      "validation": {
        "type": "heuristic",
        "schema": {
          "type": "object",
          "properties": {
            "supervised": { "type": "number" },
            "completed": { "type": "number" }
          },
          "required": ["supervised", "completed"],
          "additionalProperties": false
        }
      }
    },
    {
      "id": "q_tcc5y",
      "question": "How many undergraduate thesis projects or research projects has the researcher supervised in the last five years?",
      "tags": ["objective", "context-dependent", "complex"],
      "validation": {
        "type": "judge"
      }
    }
  ]
}
