{
  "id": "exp_basic_001",
  "name": "basic benchmark example",
  "dataset": {
    "questions": "datasets/lattes/questions.json",
    "contexts": "datasets/lattes/cvs",
    "question_instances": "datasets/lattes/questions.instance.json"
  },
  "factors": {
    "model": [
      { "provider": "openai", "name": "gpt-5.4-nano" },
      { "provider": "google", "name": "gemini-3.1-flash-lite-preview" }
    ],
    "strategy": ["inline", "mcp"],
    "format": ["json", "html"]
  },
  "params": {
    "common": {
      "temperature": 0
    },
    "gemini-3.1-flash-lite-preview": {
      "temperature": 0.3
    }
  },
  "evaluation": {
    "enabled": true,
    "output": "outputs/eval",
    "jsonl": "outputs/eval/evaluation-results.jsonl",
    "judge": {
      "provider": "openai",
      "model": "gpt-5.4",
      "temperature": 0
    },
    "fallback": {
      "provider": "openai",
      "model": "gpt-5.4-mini",
      "temperature": 0
    }
  },
  "trace": {
    "enabled": true,
    "save_raw_response": true,
    "save_tool_calls": true,
    "save_usage": true,
    "save_errors": true
  },
  "execution": {
    "repeats": 1,
    "output": "outputs/"
  }
}
