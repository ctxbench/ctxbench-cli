{
  "id": "lattes_full_001",
  "name": "lattes benchmark example with rate limiting",
  "output": "/home/michel/repos/doutorado/copa-benchmark/outputs",
  "dataset": "lattes/",
  "factors": {
    "model": [
      { "provider": "openai", "name": "gpt-5.4-nano" },
      { "provider": "google", "name": "gemini-3.1-flash-lite-preview" }
    ],
    "strategy": ["inline", "local_function", "local_mcp", "mcp"],
    "format": ["json", "html"]
  },
  "params": {
    "common": {
      "temperature": 0,
      "mcp_server": {
        "server_url": "https://example.invalid/mcp",
        "server_label": "lattes"
      }
    },
    "gpt-5.4-nano": {
      "max_output_tokens": 1000,
      "rate_limit": {
        "tpm": 200000,
        "max_concurrency": 1,
        "max_attempts": 5,
        "base_delay_ms": 1000,
        "max_delay_ms": 20000,
        "estimated_output_tokens": 1000
      }
    },
    "gemini-3.1-flash-lite-preview": {
      "temperature": 0.3,
      "max_output_tokens": 1000,
      "rate_limit": {
        "tpm": 200000,
        "max_concurrency": 1,
        "max_attempts": 5,
        "base_delay_ms": 1000,
        "max_delay_ms": 20000,
        "estimated_output_tokens": 1000
      }
    }
  },
  "evaluation": {
    "enabled": true,
    "judge": {
      "provider": "openai",
      "model": "gpt-5.4-mini",
      "temperature": 0
    },
    "fallback": {
      "provider": "openai",
      "model": "gpt-5.4-mini",
      "temperature": 0
    }
  },
  "trace": {
    "enabled": true,
    "save_raw_response": true,
    "save_tool_calls": true,
    "save_usage": true,
    "save_errors": true
  },
  "execution": {
    "repeats": 1
  }
}
