{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copa-benchmark.org/schemas/runspec.schema.json",
  "title": "COPA RunSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "runspecId",
    "suite",
    "task",
    "instance",
    "strategy",
    "provider",
    "budgets",
    "factorLevels"
  ],
  "properties": {
    "kind": { "const": "copa.runspec" },
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "runspecId": { "type": "string", "minLength": 1 },

    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },

    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "variant": { "type": "string" },
        "constraints": { "type": "object", "additionalProperties": true }
      }
    },

    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "inputs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["question", "artifacts"],
          "properties": {
            "question": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "text"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "text": { "type": "string", "minLength": 1 }
              }
            },
            "artifacts": {
              "type": "array",
              "items": { "$ref": "#/$defs/ArtifactRef" }
            }
          }
        },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },

    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["inline", "tool", "rag", "hybrid"]
        },
        "representation": { "$ref": "#/$defs/Representation" },
        "config": { "type": "object", "additionalProperties": true }
      }
    },

    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "params"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "params": { "$ref": "#/$defs/ModelParams" }
      }
    },

    "toolProvider": {
      "description": "Optional; used by tool/hybrid strategies.",
      "$ref": "#/$defs/ToolProvider"
    },

    "retrieval": {
      "description": "Optional; used by rag/hybrid strategies.",
      "$ref": "#/$defs/RetrievalConfig"
    },

    "budgets": { "$ref": "#/$defs/Budgets" },

    "repeat": {
      "description": "Replication metadata (NOT a factor). Generator should set when plan.repeats > 1.",
      "type": "object",
      "additionalProperties": false,
      "required": ["index"],
      "properties": {
        "index": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer" }
      }
    },

    "factorLevels": {
      "description": "Concrete level selection for every factor from the plan, including user-defined factors.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },

    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "createdFromPlanId": { "type": "string" },
        "gitCommit": { "type": "string" },
        "runnerVersion": { "type": "string" }
      }
    }
  },

  "$defs": {
    "ArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "uri"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "mime": { "type": "string" },
        "role": { "type": "string", "default": "primary_document" },
        "hash": { "type": "string" }
      }
    },

    "Representation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["text", "json", "xml", "markdown", "html"]
        },
        "mime": { "type": "string" }
      }
    },

    "ModelParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_name": { "type": "string", "minLength": 1 },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "topP": { "type": "number", "minimum": 0, "maximum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer" }
      }
    },

    "ToolProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["mcp-stdio", "http-json", "jsonrpc-stdio"]
        },
        "toolsetId": { "type": "string" },
        "endpoint": { "type": "string" },
        "command": { "type": "array", "items": { "type": "string" } },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "RetrievalConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["bm25", "vector", "hybrid"] },
        "indexId": { "type": "string" },
        "topK": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 5
        },
        "minScore": { "type": "number" },
        "filters": { "type": "object", "additionalProperties": true }
      }
    },

    "Budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxContextTokens": { "type": "integer", "minimum": 1 },
        "maxToolCalls": { "type": "integer", "minimum": 0 },
        "maxModelCalls": { "type": "integer", "minimum": 1 },
        "maxWallTimeSeconds": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
