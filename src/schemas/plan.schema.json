{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctxbench-benchmark.org/schemas/runplan.schema.json",
  "title": "CTXBench RunPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "planId",
    "suite",
    "selection",
    "factors",
    "repeats",
    "defaults",
    "runner",
    "recording"
  ],
  "properties": {
    "kind": { "const": "ctxbench.runplan" },
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },

    "planId": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },

    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "config": { "type": "object", "additionalProperties": true }
      }
    },

    "selection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "taskIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "instanceIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/SelectionFilter" }
        },
        "maxInstances": { "type": "integer", "minimum": 1 }
      }
    },

    "repeats": {
      "description": "Number of replications per (task instance × factor cell). This is NOT a factor.",
      "type": "integer",
      "minimum": 1,
      "maximum": 100000,
      "default": 1
    },

    "factors": {
      "description": "Experiment axes. Must include base factors; may include arbitrary user-defined factors.",
      "type": "object",
      "required": ["providers", "strategies"],
      "additionalProperties": { "$ref": "#/$defs/Factor" },
      "properties": {
        "providers": { "$ref": "#/$defs/FactorProviders" },
        "strategies": { "$ref": "#/$defs/FactorStrategies" }
      }
    },

    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modelParams": { "$ref": "#/$defs/ModelParams" },
        "budgets": { "$ref": "#/$defs/Budgets" },
        "strategyParams": { "type": "object", "additionalProperties": true },
        "toolProvider": { "$ref": "#/$defs/ToolProvider" },
        "retrieval": { "$ref": "#/$defs/RetrievalConfig" }
      }
    },

    "runner": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxParallel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024,
          "default": 4
        },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "default": 0
        },
        "resume": { "type": "boolean", "default": true },
        "seedPolicy": {
          "type": "string",
          "enum": ["fixed", "per-run", "per-instance"],
          "default": "per-run"
        },
        "seed": {
          "description": "Used when seedPolicy=fixed; otherwise ignored.",
          "type": "integer"
        }
      }
    },

    "recording": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outputDir", "writeTraceFiles"],
      "properties": {
        "outputDir": { "type": "string", "minLength": 1 },
        "writeTraceFiles": { "type": "boolean", "default": true },
        "traceFormat": {
          "type": "string",
          "enum": ["jsonl", "json"],
          "default": "jsonl"
        },
        "resultFormat": {
          "type": "string",
          "enum": ["jsonl", "json"],
          "default": "jsonl"
        },
        "artifactPolicy": {
          "type": "string",
          "enum": ["copy", "reference", "content-addressed"],
          "default": "content-addressed"
        }
      }
    },

    "provenance": { "$ref": "#/$defs/Provenance" }
  },

  "$defs": {
    "SelectionFilter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "op", "value"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "op": {
          "type": "string",
          "enum": ["=", "!=", "in", "not-in", "contains", "regex"]
        },
        "value": {}
      }
    },

    "Factor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["levels"],
      "properties": {
        "label": { "type": "string" },
        "description": { "type": "string" },
        "levels": { "type": "array", "minItems": 1, "items": {} },
        "default": {},
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },

    "FactorProviders": {
      "allOf": [
        { "$ref": "#/$defs/Factor" },
        {
          "properties": {
            "levels": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/ProviderRef" }
            }
          }
        }
      ]
    },

    "FactorStrategies": {
      "allOf": [
        { "$ref": "#/$defs/Factor" },
        {
          "properties": {
            "levels": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/StrategyRef" }
            }
          }
        }
      ]
    },

    "ProviderRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "endpoint": { "type": "string" }
      }
    },

    "StrategyRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["inline", "tool", "rag", "hybrid"]
        },
        "label": { "type": "string" },
        "config": { "type": "object", "additionalProperties": true }
      }
    },

    "ModelParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "topP": { "type": "number", "minimum": 0, "maximum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer" }
      }
    },

    "Budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxContextTokens": { "type": "integer", "minimum": 1 },
        "maxToolCalls": { "type": "integer", "minimum": 0 },
        "maxModelCalls": { "type": "integer", "minimum": 1 },
        "maxWallTimeSeconds": { "type": "integer", "minimum": 1 }
      }
    },

    "ToolProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["mcp-stdio", "http-json", "jsonrpc-stdio"]
        },
        "toolsetId": { "type": "string" },
        "endpoint": { "type": "string" },
        "command": { "type": "array", "items": { "type": "string" } },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "RetrievalConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["bm25", "vector", "hybrid"] },
        "indexId": { "type": "string" },
        "topK": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 5
        },
        "minScore": { "type": "number" },
        "filters": { "type": "object", "additionalProperties": true }
      }
    },

    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "createdBy": { "type": "string" },
        "gitCommit": { "type": "string" },
        "gitRepo": { "type": "string" },
        "runnerVersion": { "type": "string" }
      }
    }
  }
}
